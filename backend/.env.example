# Nemotron API access via build.nvidia.com/models
NVIDIA_API_KEY=
NEMOTRON_MODEL=nvidia/nemotron-super-120b-a12b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# NemoClaw config (fill in once integrating)
# NEMOCLAW_POLICY_PATH=./policy.yaml

# Supabase
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_KEY=<your-service-role-key>
# Found in Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=<your-jwt-secret>
# NemoClaw / OpenShell sandbox config
NEMOCLAW_POLICY_PATH=./policy.yaml
NEMOCLAW_SANDBOX_NAME=agent-app-sandbox
# On Brev, inference routes through a local endpoint — override when inside sandbox:
# NVIDIA_BASE_URL=http://inference.local/v1

# Optional: enables real web search via Tavily (https://tavily.com)
# TAVILY_API_KEY=
